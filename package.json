{
  "name": "homelab-monitor-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "verify": "pnpm --filter ui run verify",
    "lint": "pnpm --filter ui run lint",
    "typecheck": "pnpm --filter ui run typecheck",
    "test": "pnpm --filter ui run test",
    "build": "pnpm --filter ui run build"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=7.28.0 <8",
      "brace-expansion": ">=5.0.6",
      "js-yaml": ">=4.2.0 <5",
      "@babel/core": ">=7.29.6 <8"
    }
  }
}
