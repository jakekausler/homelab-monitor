{
  "name": "@homelab-monitor/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "typecheck": "tsc -b",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "generate-types": "openapi-typescript ../../packages/shared-types/openapi.json -o src/api/schema.ts",
    "verify": "pnpm run generate-types && pnpm run lint && pnpm run format-check && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@radix-ui/react-dropdown-menu": "^2.1",
    "@radix-ui/react-label": "^2.1",
    "@radix-ui/react-slot": "^1.1",
    "@radix-ui/react-tooltip": "^1.1",
    "@tanstack/react-query": "^5.62",
    "@tanstack/react-router": "^1.95",
    "class-variance-authority": "^0.7",
    "clsx": "^2.1",
    "lucide-react": "^0.469",
    "openapi-fetch": "^0.13",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.54",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.0",
    "tailwindcss": "^4.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query-devtools": "^5.62",
    "@tanstack/router-devtools": "^1.95",
    "@testing-library/jest-dom": "^6.6",
    "@testing-library/react": "^16.1",
    "@testing-library/user-event": "^14.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@eslint-react/eslint-plugin": "^5.7.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.5",
    "prettier": "^3.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
