{
  "name": "@homelab-monitor/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --cache --cache-location node_modules/.cache/.eslintcache",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "typecheck": "tsc -b",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "generate-types": "openapi-typescript ../../packages/shared-types/openapi.json -o src/api/schema.ts",
    "verify": "pnpm run generate-types && pnpm run lint && pnpm run format-check && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dropdown-menu": "^2.1",
    "@radix-ui/react-label": "^2.1",
    "@radix-ui/react-slot": "^1.1",
    "@radix-ui/react-tooltip": "^1.1",
    "@tanstack/react-query": "^5.100",
    "@tanstack/react-router": "^1.170",
    "class-variance-authority": "^0.7",
    "clsx": "^2.1",
    "lucide-react": "^0.469",
    "openapi-fetch": "^0.17",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.100",
    "@tanstack/router-devtools": "^1.167",
    "@testing-library/jest-dom": "^6.6",
    "@testing-library/react": "^16.1",
    "@testing-library/user-event": "^14.5",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@eslint-react/eslint-plugin": "^5.8.5",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.5",
    "prettier": "^3.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
