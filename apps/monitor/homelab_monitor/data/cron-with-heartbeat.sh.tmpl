#!/bin/sh
# DO NOT EDIT — generated by homelab-monitor `cron install-wrapper`.
#
# Generic cron heartbeat + run-capture wrapper. BYTE-IDENTICAL for every cron:
# the fingerprint is positional argument $1, the heartbeat URL base is read at
# runtime from the wrapper.env file. A future wrapper-logic upgrade is a single
# shared-file replacement — no per-cron re-install, no crontab edit.
#
# wrapper_format_version: {{WRAPPER_FORMAT_VERSION}}
#
# Usage (the rewritten crontab line):
#   cron-with-heartbeat.sh <fingerprint> -- <real command and args>
#
# Behavior: generates a per-run UUID; emits HM_RUN_START / HM_RUN_END journald
# boundary markers under SYSLOG_IDENTIFIER=hmrun; runs the real command with
# every output line copied (prefixed `HM_RUN=<uuid> `) through `logger --tag
# hmrun`; the ORIGINAL un-prefixed output still goes to stdout/stderr. Heartbeat
# POSTs (/start, /ok|/fail) are best-effort and bounded — a network failure
# NEVER blocks or alters the real command. The real command's exit code is
# ALWAYS preserved and returned as this wrapper's exit code.

set -u

WRAPPER_FORMAT_VERSION='{{WRAPPER_FORMAT_VERSION}}'
TOKEN_FILE='{{TOKEN_FILE_PATH}}'
ENV_FILE='{{WRAPPER_ENV_PATH}}'

# --- Arg parsing: `<fingerprint> -- <command...>` ---------------------------
FINGERPRINT="${1:-}"
if [ -z "$FINGERPRINT" ]; then
	echo "cron-with-heartbeat.sh: missing <fingerprint> argument" >&2
	exit 64
fi
shift
if [ "${1:-}" != "--" ]; then
	echo "cron-with-heartbeat.sh: expected '--' separator after fingerprint" >&2
	exit 64
fi
shift
# Everything remaining ("$@") is the real command.

# --- Read the heartbeat URL base from the env file --------------------------
# The env file holds a single line `HEARTBEAT_URL_BASE=...`. Sourcing it is the
# simplest POSIX way; the file is wrapper-managed and trusted (mode 644).
URL_BASE=''
if [ -r "$ENV_FILE" ]; then
	# shellcheck disable=SC1090
	. "$ENV_FILE" 2>/dev/null || true
	URL_BASE="${HEARTBEAT_URL_BASE:-}"
fi

# --- Read the bearer token (best-effort; empty if unreadable) ---------------
TOKEN=''
if [ -r "$TOKEN_FILE" ]; then
	TOKEN=$(cat "$TOKEN_FILE" 2>/dev/null) || TOKEN=''
fi

# --- Generate the run UUID --------------------------------------------------
# /proc/sys/kernel/random/uuid is always present on Linux; uuidgen is the
# fallback. Absolute paths — cron's PATH is minimal. If both fail, RUN_ID stays
# empty and capture degrades (the command still runs).
RUN_ID=''
if [ -r /proc/sys/kernel/random/uuid ]; then
	RUN_ID=$(cat /proc/sys/kernel/random/uuid 2>/dev/null) || RUN_ID=''
fi
if [ -z "$RUN_ID" ]; then
	for _uuidgen in /usr/bin/uuidgen /bin/uuidgen; do
		if [ -x "$_uuidgen" ]; then
			RUN_ID=$("$_uuidgen" 2>/dev/null) || RUN_ID=''
			[ -n "$RUN_ID" ] && break
		fi
	done
fi

# --- Helpers ----------------------------------------------------------------
# hb_post <path-suffix> — best-effort heartbeat POST. Bounded, output discarded,
# never fails the script. Skipped entirely if URL_BASE is empty.
hb_post() {
	[ -n "$URL_BASE" ] || return 0
	curl --silent --show-error --max-time 5 \
		-X POST \
		-H "Authorization: Bearer $TOKEN" \
		"$URL_BASE/api/hb/$FINGERPRINT/$1" >/dev/null 2>&1 || true
}

# log_marker <message> — best-effort journald marker under tag hmrun. `logger`
# missing or failing must NEVER break the cron.
log_marker() {
	command -v logger >/dev/null 2>&1 || return 0
	logger --tag hmrun -- "$1" 2>/dev/null || true
}

# --- Start boundary ---------------------------------------------------------
START_EPOCH=$(date +%s.%N)
log_marker "HM_RUN_START fp=$FINGERPRINT run=$RUN_ID"
if [ -n "$RUN_ID" ]; then
	hb_post "start?run_id=$RUN_ID"
else
	hb_post "start"
fi

# --- Run the real command with per-line capture -----------------------------
# Exit-code preservation: the read-loop runs in a SUBSHELL of the pipeline, so
# the real command's exit code cannot travel through a shell variable. It is
# written to a temp file by `echo $? > "$CODEFILE"` and read back afterward.
# Pure POSIX — no pipefail, no $PIPESTATUS, no mkfifo.
#
# The `while read` loop echoes each line to stdout (original output preserved)
# AND, if logger is available and a RUN_ID exists, pipes a `HM_RUN=<uuid> `-
# prefixed copy through `logger --tag hmrun`. stderr is merged into stdout via
# 2>&1 so stderr lines are captured too; both are echoed back to the wrapper's
# stdout. (Splitting stderr back out is not POSIX-feasible without named pipes;
# merging is the accepted, documented behavior — journald gets both streams
# tagged, and the human sees combined output, same as `cmd 2>&1`.)
CODEFILE=$(mktemp 2>/dev/null) || CODEFILE=''
# Clean the temp file on any exit path.
trap '[ -n "$CODEFILE" ] && rm -f "$CODEFILE"' EXIT INT TERM

if [ -n "$CODEFILE" ]; then
	{ "$@" 2>&1; echo $? > "$CODEFILE"; } | while IFS= read -r _line; do
		printf '%s\n' "$_line"
		if [ -n "$RUN_ID" ] && command -v logger >/dev/null 2>&1; then
			printf 'HM_RUN=%s %s\n' "$RUN_ID" "$_line" \
				| logger --tag hmrun 2>/dev/null || true
		fi
	done
	# Read the real command's exit code back from the temp file. A missing or
	# unreadable codefile (the command's subshell never wrote it) falls back to
	# a non-zero exit so a swallowed failure is never reported as success.
	EXIT_CODE=$(cat "$CODEFILE" 2>/dev/null) || EXIT_CODE=''
	case "$EXIT_CODE" in
		''|*[!0-9]*) EXIT_CODE=1 ;;
	esac
else
	# mktemp failed — degrade to a plain run with no capture. Exit code is the
	# command's own (no pipeline, so $? is exact).
	"$@"
	EXIT_CODE=$?
fi

# --- End boundary -----------------------------------------------------------
END_EPOCH=$(date +%s.%N)
# POSIX $((...)) is integer-only; use awk so the fractional delta is preserved.
DURATION=$(awk "BEGIN { printf \"%.3f\", $END_EPOCH - $START_EPOCH }")
log_marker "HM_RUN_END fp=$FINGERPRINT run=$RUN_ID exit=$EXIT_CODE duration=$DURATION"

# --- Report ok/fail ---------------------------------------------------------
# exit_code is sent on BOTH /ok (0) and /fail (the non-zero code).
_run_q=''
[ -n "$RUN_ID" ] && _run_q="run_id=$RUN_ID&"
if [ "$EXIT_CODE" -eq 0 ]; then
	hb_post "ok?${_run_q}duration=$DURATION&exit_code=$EXIT_CODE"
else
	hb_post "fail?${_run_q}duration=$DURATION&exit_code=$EXIT_CODE"
fi

exit "$EXIT_CODE"
