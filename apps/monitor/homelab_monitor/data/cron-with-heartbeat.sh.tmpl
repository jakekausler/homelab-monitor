#!/bin/sh
# DO NOT EDIT — generated by `hm cron install-wrapper` on {{INSTALL_DATE}}; fingerprint={{FINGERPRINT}}
#
# Heartbeat wrapper for a single cron. Records start, runs the real command,
# reports ok/fail with duration + exit code. Heartbeat POSTs are best-effort:
# a network failure NEVER blocks or alters the real command's behavior.
#
# Usage (from the rewritten crontab line):
#   {{TOKEN_FILE_PATH}} is read for the bearer token.
#   cron-with-heartbeat.sh -- <real command and args>

set -u

FINGERPRINT='{{FINGERPRINT}}'
URL_BASE='{{HEARTBEAT_URL_BASE}}'
TOKEN_FILE='{{TOKEN_FILE_PATH}}'

# Everything after the literal `--` is the real command.
if [ "${1:-}" != "--" ]; then
	echo "cron-with-heartbeat.sh: expected '--' separator before command" >&2
	exit 64
fi
shift

# Read the bearer token (best-effort; empty if unreadable).
TOKEN=''
if [ -r "$TOKEN_FILE" ]; then
	TOKEN=$(cat "$TOKEN_FILE" 2>/dev/null) || TOKEN=''
fi

hb_post() {
	# $1 = path suffix (e.g. start, "ok?duration=3")
	# Best-effort: bounded time, all output discarded, never fails the script.
	curl --silent --show-error --max-time 5 \
		-X POST \
		-H "Authorization: Bearer $TOKEN" \
		"$URL_BASE/api/hb/$FINGERPRINT/$1" >/dev/null 2>&1 || true
}

START_EPOCH=$(date +%s)
hb_post "start"

# Run the real command. Capture its exit code without aborting on `set -u`.
"$@"
EXIT_CODE=$?

END_EPOCH=$(date +%s)
DURATION=$((END_EPOCH - START_EPOCH))

if [ "$EXIT_CODE" -eq 0 ]; then
	hb_post "ok?duration=$DURATION"
else
	hb_post "fail?duration=$DURATION&exit_code=$EXIT_CODE"
fi

exit "$EXIT_CODE"
