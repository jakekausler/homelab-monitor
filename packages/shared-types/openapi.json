{
  "components": {
    "schemas": {
      "ChangePasswordRequest": {
        "additionalProperties": false,
        "properties": {
          "current_password": {
            "minLength": 1,
            "title": "Current Password",
            "type": "string"
          },
          "new_password": {
            "minLength": 1,
            "title": "New Password",
            "type": "string"
          }
        },
        "required": [
          "current_password",
          "new_password"
        ],
        "title": "ChangePasswordRequest",
        "type": "object"
      },
      "CollectorStatus": {
        "additionalProperties": false,
        "description": "Status of a single collector in GET /api/collectors response.",
        "properties": {
          "consecutive_failures": {
            "title": "Consecutive Failures",
            "type": "integer"
          },
          "interval_seconds": {
            "title": "Interval Seconds",
            "type": "number"
          },
          "last_error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Error"
          },
          "last_run": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Run"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "next_run": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Next Run"
          },
          "quarantine_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Quarantine Reason"
          },
          "quarantined": {
            "title": "Quarantined",
            "type": "boolean"
          },
          "quarantined_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Quarantined At"
          },
          "run_kind": {
            "title": "Run Kind",
            "type": "string"
          },
          "status": {
            "enum": [
              "healthy",
              "quarantined",
              "degraded"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "name",
          "status",
          "last_run",
          "last_error",
          "quarantined",
          "quarantined_at",
          "quarantine_reason",
          "next_run",
          "run_kind",
          "interval_seconds",
          "consecutive_failures"
        ],
        "title": "CollectorStatus",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthzResponse": {
        "additionalProperties": false,
        "description": "Response for GET /api/healthz.",
        "properties": {
          "db": {
            "enum": [
              "up",
              "down"
            ],
            "title": "Db",
            "type": "string"
          },
          "degraded_collectors": {
            "items": {
              "type": "string"
            },
            "title": "Degraded Collectors",
            "type": "array"
          },
          "failed_ticks_last_5m": {
            "title": "Failed Ticks Last 5M",
            "type": "integer"
          },
          "last_tick_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Tick At"
          },
          "ok": {
            "title": "Ok",
            "type": "boolean"
          },
          "quarantined_collectors": {
            "items": {
              "type": "string"
            },
            "title": "Quarantined Collectors",
            "type": "array"
          },
          "scheduler": {
            "enum": [
              "running",
              "stopped"
            ],
            "title": "Scheduler",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "ok",
          "version",
          "db",
          "scheduler",
          "last_tick_at",
          "failed_ticks_last_5m",
          "quarantined_collectors",
          "degraded_collectors"
        ],
        "title": "HealthzResponse",
        "type": "object"
      },
      "LoginRequest": {
        "additionalProperties": false,
        "properties": {
          "password": {
            "minLength": 1,
            "title": "Password",
            "type": "string"
          },
          "username": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Username",
            "type": "string"
          }
        },
        "required": [
          "username",
          "password"
        ],
        "title": "LoginRequest",
        "type": "object"
      },
      "LoginResponse": {
        "additionalProperties": false,
        "description": "Response for POST /api/auth/login. Same shape as MeResponse but kept\ndistinct so OpenAPI consumers see endpoint-specific schema names.",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserResponse"
          }
        },
        "required": [
          "user"
        ],
        "title": "LoginResponse",
        "type": "object"
      },
      "MeResponse": {
        "additionalProperties": false,
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserResponse"
          }
        },
        "required": [
          "user"
        ],
        "title": "MeResponse",
        "type": "object"
      },
      "MetricsSnapshotEntry": {
        "additionalProperties": false,
        "description": "Single metric entry in a snapshot.",
        "properties": {
          "kind": {
            "title": "Kind",
            "type": "string"
          },
          "labels": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Labels",
            "type": "object"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "ts": {
            "title": "Ts",
            "type": "string"
          },
          "value": {
            "title": "Value",
            "type": "number"
          }
        },
        "required": [
          "name",
          "value",
          "labels",
          "kind",
          "ts"
        ],
        "title": "MetricsSnapshotEntry",
        "type": "object"
      },
      "MetricsSnapshotResponse": {
        "additionalProperties": false,
        "description": "Response for GET /api/metrics/snapshot.",
        "properties": {
          "entries": {
            "items": {
              "$ref": "#/components/schemas/MetricsSnapshotEntry"
            },
            "title": "Entries",
            "type": "array"
          },
          "ts": {
            "title": "Ts",
            "type": "string"
          }
        },
        "required": [
          "ts",
          "entries"
        ],
        "title": "MetricsSnapshotResponse",
        "type": "object"
      },
      "RetryResponse": {
        "additionalProperties": false,
        "description": "Response for POST /api/collectors/{name}/retry.",
        "properties": {
          "name": {
            "title": "Name",
            "type": "string"
          },
          "requested_at": {
            "title": "Requested At",
            "type": "string"
          },
          "tick_id": {
            "title": "Tick Id",
            "type": "string"
          }
        },
        "required": [
          "name",
          "tick_id",
          "requested_at"
        ],
        "title": "RetryResponse",
        "type": "object"
      },
      "UserResponse": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "username": {
            "title": "Username",
            "type": "string"
          }
        },
        "required": [
          "id",
          "username"
        ],
        "title": "UserResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "VersionResponse": {
        "additionalProperties": false,
        "description": "Response for GET /api/version.",
        "properties": {
          "built_at": {
            "title": "Built At",
            "type": "string"
          },
          "git_sha": {
            "title": "Git Sha",
            "type": "string"
          },
          "users_configured": {
            "title": "Users Configured",
            "type": "boolean"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "version",
          "git_sha",
          "built_at",
          "users_configured"
        ],
        "title": "VersionResponse",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "homelab-monitor",
    "version": "0.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/auth/change-password": {
      "post": {
        "description": "Verify current password; change to new; rotate session.",
        "operationId": "change_password_api_auth_change_password_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Change Password",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/auth/login": {
      "post": {
        "description": "Authenticate username/password; issue session + CSRF cookies.\n\nRate limiting: only failed attempts count against the budget. Successful\nlogins do NOT consume a slot, so a legitimate user repeatedly logging in\nis never throttled.",
        "operationId": "login_api_auth_login_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Login",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/auth/logout": {
      "post": {
        "description": "Delete session row + clear cookies. Requires session + CSRF.",
        "operationId": "logout_api_auth_logout_post",
        "responses": {
          "204": {
            "description": "Successful Response"
          }
        },
        "summary": "Logout",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/auth/me": {
      "get": {
        "description": "Return the current authenticated user.",
        "operationId": "me_api_auth_me_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Me",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/collectors": {
      "get": {
        "description": "List all loaded collectors with their status.",
        "operationId": "list_collectors_api_collectors_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/CollectorStatus"
                  },
                  "title": "Response List Collectors Api Collectors Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "List Collectors"
      }
    },
    "/api/collectors/{name}/retry": {
      "post": {
        "description": "Request an immediate retry of a collector.\n\nClears any quarantine, enqueues an immediate run, and returns the tick_id.",
        "operationId": "retry_collector_api_collectors__name__retry_post",
        "parameters": [
          {
            "in": "path",
            "name": "name",
            "required": true,
            "schema": {
              "title": "Name",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RetryResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Retry Collector"
      }
    },
    "/api/events": {
      "get": {
        "description": "Stream collector tick events via Server-Sent Events.\n\nConnects to the SSE broker and yields events in the format:\n  event: collector.tick\n  data: {JSON payload}\n  id: {sequence number}\n\nReplays the last 50 events on connect. If the consumer's queue fills\n(slow subscriber), the broker disconnects them with an error event.",
        "operationId": "stream_events_api_events_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Stream Events"
      }
    },
    "/api/healthz": {
      "get": {
        "description": "Health check endpoint.\n\nReturns overall system health plus detailed status fields. Tolerant of\nmissing dependencies (lifespan disabled / not yet started) \u2014 reports\ndegraded state instead of 503-ing.",
        "operationId": "healthz_api_healthz_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthzResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Healthz"
      }
    },
    "/api/metrics/snapshot": {
      "get": {
        "description": "Return the in-memory writer's latest-value snapshot.\n\nAuth: cookie session required. CSRF NOT enforced on GET.\n\nSCAFFOLDING: when a real VictoriaMetrics-backed writer ships in STAGE-001-015,\nthis endpoint will be retired in favor of direct VM queries. STAGE-014's\nOverview tile is the only consumer.",
        "operationId": "metrics_snapshot_api_metrics_snapshot_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetricsSnapshotResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Metrics Snapshot"
      }
    },
    "/api/version": {
      "get": {
        "description": "Version endpoint. Returns version, git SHA, build timestamp, users_configured.",
        "operationId": "version_api_version_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Version"
      }
    }
  }
}
