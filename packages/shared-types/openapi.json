    "/api/alerts/ingest": {
      "post": {
        "description": "Ingest an Alertmanager v2 webhook payload.\n\nFor each alert in ``payload.alerts``:\n\n- Compute the fingerprint via ``compute_fingerprint``.\n- If ``status == \"firing\"``: dedupe by fingerprint. Bump ``last_seen_at`` if\n  a row exists, else insert a new firing row. Dispatch ``AlertFiringEvent``.\n- If ``status == \"resolved\"``: look up the active row by fingerprint. If\n  found, mark resolved + dispatch ``AlertResolvedEvent``. If not found,\n  log INFO + skip (no row created).\n\nReturns 202 with ``{\"received\": int, \"ingested\": int}``. ``ingested`` counts\nitems that produced a state change (firing dedup-or-insert OR resolved\nmatching an active row).",
        "operationId": "ingest_alerts_api_alerts_ingest_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AlertmanagerV2Payload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Ingest Alerts",
        "tags": [
          "alerts"
        ]
      }
    },
