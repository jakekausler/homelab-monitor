      "title": "Device fleet (up + firmware)",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [ { "id": "unit", "value": "percent" } ]
          },
          {
            "matcher": { "id": "byName", "options": "Mem %" },
            "properties": [ { "id": "unit", "value": "percent" } ]
          },
          {
            "matcher": { "id": "byName", "options": "Uptime" },
            "properties": [ { "id": "unit", "value": "dtdurations" } ]
          },
          {
            "matcher": { "id": "byName", "options": "Up" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "mappings", "value": [
                { "type": "value", "options": {
                  "1": { "text": "Up", "color": "green", "index": 0 },
                  "0": { "text": "Down", "color": "red", "index": 1 }
                }}
              ]}
            ]
          }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false, "reducer": ["sum"], "countRows": false, "fields": "" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "max by (device, kind, model) (homelab_unifi_device_up)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "max by (device) (homelab_unifi_device_cpu_percent)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "max by (device) (homelab_unifi_device_mem_percent)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "max by (device) (homelab_unifi_device_uptime_seconds)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "E",
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "max by (device) (homelab_unifi_device_update_available)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service": true
            },
            "indexByName": {
              "device": 0,
              "kind": 1,
              "model": 2,
              "Value #A": 3,
              "Value #B": 4,
              "Value #C": 5,
              "Value #D": 6,
              "Value #E": 7
            },
            "renameByName": {
              "device": "Device",
              "kind": "Kind",
              "model": "Model",
              "Value #A": "Up",
              "Value #B": "CPU %",
              "Value #C": "Mem %",
              "Value #D": "Uptime",
              "Value #E": "Update?"
            }
          }
        }
      ]
