    {
      "id": 83,
      "type": "timeseries",
      "title": "Top apps by DPI throughput (excl. SSL/TLS)",
      "description": "topk(10) of per-app DPI byte rate. clamp_max guards Ubiquiti's per-counter spike bug (spurious resets inflate rate()); ceiling is 125000000 B/s (~1 Gbps WAN line rate). app=\"15\" is a source-side unresolved app id, shown as-is. interval=5m is required: DPI is polled every 300s so $__rate_interval must be >= 5m for rate() to see data. SSL/TLS is excluded (it's a broad catch-all that dominates and obscures real apps).",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 112
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "topk(10, clamp_max(sum by (app) (rate(homelab_unifi_client_dpi_bytes{app!=\"SSL/TLS\"}[$__rate_interval])), 125000000))",
          "legendFormat": "{{app}}",
          "interval": "5m",
          "range": true
        }
      ]
    },
