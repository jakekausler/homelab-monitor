    {
      "id": 21,
      "type": "gauge",
      "title": "DHCP pool occupancy %",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 22 },
      "description": "Pool occupancy = leased-or-active clients / DHCP pool size, on network=Default. Prefers the SSH lease collector (`homelab_unifi_dhcp_lease_count`) when enabled; otherwise approximates with the active client count. Reads ~22% currently (lease collector OFF). VERIFY this expr returns a value live in Refinement — if the `or` fallback misbehaves, fall back to the `scalar() or scalar()` form noted in the spec.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 } ] },
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "(sum(homelab_unifi_dhcp_lease_count) or sum(homelab_unifi_client_count_by_network{network=\"Default\"})) / scalar(homelab_unifi_dhcp_pool_size{network=\"Default\"}) * 100", "legendFormat": "occupancy", "range": true }
      ]
    },
