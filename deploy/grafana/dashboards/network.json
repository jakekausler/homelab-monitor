      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "WAN up",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] },
          "mappings": [ { "type": "value", "options": { "1": { "text": "Up", "color": "green", "index": 0 }, "0": { "text": "Down", "color": "red", "index": 1 } } } ]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "homelab_unifi_wan_up", "legendFormat": "up", "instant": true } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "WAN latency",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.15 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "homelab_unifi_wan_latency_seconds", "legendFormat": "latency", "instant": true } ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "WAN failover active",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] },
          "mappings": [ { "type": "value", "options": { "0": { "text": "Inactive", "color": "green", "index": 0 }, "1": { "text": "ACTIVE", "color": "red", "index": 1 } } } ]
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "homelab_unifi_wan_failover_active", "legendFormat": "failover", "instant": true } ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Last speedtest",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "description": "Time since the UDM last ran a speedtest. Note: the last recorded run returned 0 Mbps down/up/ping — that is a UDM 0-result, not missing data.",
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeFromNow",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "homelab_unifi_speedtest_lastrun * 1000", "legendFormat": "lastrun", "instant": true } ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "WAN throughput (Mbps)",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "Mbits", "color": { "mode": "palette-classic" }, "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "homelab_unifi_wan_xput_down_bytes_per_sec * 8 / 1e6", "legendFormat": "down", "range": true },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "homelab_unifi_wan_xput_up_bytes_per_sec * 8 / 1e6", "legendFormat": "up", "range": true }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Speedtest down/up (Mbps)",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "description": "0 = last UDM speedtest run returned 0, not missing data. The series will sit at 0 until a non-zero UDM run lands.",
      "fieldConfig": { "defaults": { "unit": "Mbits", "color": { "mode": "palette-classic" }, "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "homelab_unifi_speedtest_download_mbps", "legendFormat": "download", "range": true },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "homelab_unifi_speedtest_upload_mbps", "legendFormat": "upload", "range": true }
