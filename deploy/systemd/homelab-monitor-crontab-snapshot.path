[Unit]
Description=Watch host crontab spool for changes (homelab-monitor snapshot refresh)
Documentation=https://github.com/jakekausler/homelab-monitor/blob/main/docs/architecture/cron-logscrape.md

[Path]
PathChanged=/var/spool/cron/crontabs
Unit=homelab-monitor-crontab-snapshot.service

[Install]
WantedBy=paths.target
