# homelab-monitor — local dev environment
#
# This file is the SINGLE SOURCE OF TRUTH for the local dev rig.
# `scripts/dev-up.sh` sources it; the prod compose stack reads the same vars.
#
# To use:
#   1. cp deploy/dev/dev.env.example deploy/dev/dev.env
#   2. chmod 600 deploy/dev/dev.env  (it will contain your master key)
#   3. Generate a master key:
#        python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
#      and replace GENERATE_ME_WITH_SCRIPT below.
#   4. make dev          (hybrid: docker sidecars + host backend + host UI)
#      make dev-prod     (full prod compose stack from local Dockerfile)
#      make dev-clean    (kill everything first, then `make dev`)
#      make dev-down     (graceful tear-down)
#
# `deploy/dev/dev.env` is gitignored. Never commit it.

# ============================================================================
# --- Ports ---
# All host-side ports the dev rig publishes. Bind to 127.0.0.1 only (handled
# by docker-compose.yml port-publishing). Override here if a port is taken.
# ============================================================================

# UI dev server (Vite). 5180 chosen to avoid the common 5173–5176 collision
# range when other Vite projects are running on the same host.
HM_DEV_UI_PORT=5180

# Backend uvicorn. Port 9090 collides with other services on this host
# (see CLAUDE.md), so the dev rig uses 19090.
HM_DEV_BACKEND_PORT=19090

# Sidecars (host ports — container-internal ports are unchanged).
HM_DEV_VM_PORT=8428
HM_DEV_VL_PORT=9428
HM_DEV_VMAGENT_PORT=8429
HM_DEV_VECTOR_PORT=8686
HM_DEV_AM_PORT=9093
HM_DEV_KARMA_PORT=8081
HM_DEV_VMALERT_METRICS_PORT=8880
HM_DEV_VMALERT_LOGS_PORT=8881
HM_DEV_GRAFANA_PORT=3000

# Test fixtures (only used by the test rig; harmless to leave set).
HM_DEV_FIXTURE_HOST_PORT=8000
HM_DEV_NOISY_LOGGER_PORT=8001

# kthxbye has no exposed port (alertmanager-internal only).

# ============================================================================
# --- Secrets ---
# These MUST be replaced before `dev-up.sh` will start.
# Run: python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# ============================================================================

# 32-byte base64-encoded master key for secrets encryption.
# `scripts/dev-up.sh` aborts if this still equals GENERATE_ME_WITH_SCRIPT.
HOMELAB_MONITOR_MASTER_KEY=GENERATE_ME_WITH_SCRIPT

# Default admin credentials for first-boot user creation.
# Password MUST be >= 12 chars (validated by `hm user create`).
HM_DEV_ADMIN_USERNAME=admin
HM_DEV_ADMIN_PASSWORD=admin-dev-password

# ============================================================================
# --- Backend tunables ---
# Pulled from references in apps/monitor/homelab_monitor/**/*.py.
# Hybrid mode (host backend) reads these directly from the env that
# `dev-up.sh` exports before launching uvicorn. Prod-mode docker-compose.yml
# also references many of these (see deploy/compose/.env.example).
# ============================================================================

# Database URL. SQLite under deploy/dev/data/ keeps everything inside the repo
# tree (gitignored) and avoids /tmp/ wipes between reboots.
HOMELAB_MONITOR_DB_URL=sqlite+aiosqlite:////tmp/hm-dev/homelab.db

# Run alembic migrations on startup. Required for the rig to bootstrap a
# fresh DB without manual `hm migrate up`.
HOMELAB_MONITOR_AUTO_MIGRATE=1

# bcrypt cost factor. 12 in prod; 4 in dev keeps `hm user create` and login
# under 100ms. NEVER set this to 4 in production.
HOMELAB_MONITOR_BCRYPT_COST=4

# HTTPS-only cookies. MUST be false for local http://localhost dev — the
# browser will silently drop session cookies otherwise.
HOMELAB_MONITOR_HTTPS_ONLY_COOKIES=false

# Session TTL in days (default 7). Shorter for dev so stale sessions
# don't mask login bugs.
HOMELAB_MONITOR_SESSION_TTL_DAYS=7

# API token prefix (default homelab_dev_ in dev). Real prod env uses
# homelab_prod_; the integration rig uses homelab_test_.
HOMELAB_MONITOR_TOKEN_PREFIX=homelab_dev

# Trust X-Forwarded-* headers. 0 for direct host access; set to 1 only
# when running behind nginx/caddy.
HOMELAB_MONITOR_TRUST_FORWARDED_HEADERS=0

# Log format / level for the host backend.
HOMELAB_MONITOR_LOG_FORMAT=text
HOMELAB_MONITOR_LOG_LEVEL=INFO

# ============================================================================
# --- Sidecar URLs ---
# Hybrid mode: host backend talks to docker sidecars via 127.0.0.1:<port>.
# Prod mode: docker-compose.yml uses the docker-network DNS names directly
# (http://victoriametrics:8428 etc.) and ignores these.
# ============================================================================

HOMELAB_MONITOR_VM_URL=http://127.0.0.1:8428
HOMELAB_MONITOR_VL_URL=http://127.0.0.1:9428
HOMELAB_MONITOR_ALERTMANAGER_URL=http://127.0.0.1:9093
HOMELAB_MONITOR_KARMA_URL=http://127.0.0.1:8081
HOMELAB_MONITOR_GRAFANA_URL=http://127.0.0.1:3000
HOMELAB_MONITOR_GRAFANA_TIMEOUT_S=30
HOMELAB_MONITOR_KARMA_TIMEOUT_S=30

# Data dirs (only used by collectors; safe defaults for dev).
HOMELAB_MONITOR_VM_DATA_DIR=/var/vm-data
HOMELAB_MONITOR_VL_DATA_DIR=/var/vl-data
HOMELAB_MONITOR_SQLITE_DATA_DIR=/tmp/hm-dev
HOMELAB_MONITOR_RUNBOOK_TRANSCRIPTS_DIR=/tmp/hm-dev/runbook-transcripts
HOMELAB_MONITOR_BACKUP_ROOT=/tmp/hm-dev/backup

# VM scrape timeout (seconds).
HOMELAB_MONITOR_VM_TIMEOUT_S=30

# VictoriaLogs retention period (days). Lower in dev to bound disk.
HOMELAB_MONITOR_VL_RETENTION_DAYS=7

# Disk-budget collector cap (gigabytes).
HOMELAB_MONITOR_DISK_BUDGET_GB=50

# ============================================================================
# --- Prod-compose passthroughs (only read by `make dev-prod`) ---
# ============================================================================

# Public URL Grafana advertises in its self-rendered HTML. Override when
# behind nginx/TLS (e.g., GRAFANA_PUBLIC_URL=https://homelab.example.com/api/grafana/).
GRAFANA_PUBLIC_URL=http://127.0.0.1:9090/api/grafana/

# Image tag for the prebuilt `ghcr.io/jakekausler/homelab-monitor` image.
# `make dev-prod` rebuilds locally from apps/monitor/Dockerfile, so this
# only matters if you also `docker compose pull`.
IMAGE_TAG=latest

# HOMELAB_MONITOR_PORT is the host-side bind for the prod monitor service.
# Defaults to 9090 in compose. Override here only if you need to publish on
# a different host port (e.g., HOMELAB_MONITOR_PORT=19090 to keep dev
# parity).
HOMELAB_MONITOR_PORT=9090
