# homelab-monitor compose env template — copy to .env and edit.
#
# Required:
HOMELAB_MONITOR_MASTER_KEY=  # 32-byte base64; generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
#
# Optional:
HOMELAB_MONITOR_PORT=9090
HOMELAB_MONITOR_HTTPS_ONLY_COOKIES=true
HOMELAB_MONITOR_DB_URL=sqlite+aiosqlite:////data/homelab-monitor.db
IMAGE_TAG=latest
