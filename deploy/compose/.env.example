# homelab-monitor compose env template — copy to .env and edit.
#
# Required:
HOMELAB_MONITOR_MASTER_KEY=  # 32-byte base64; generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
#
# Required for cron wrapper install (STAGE-002-009):
# The wrapper (installed on cron lines) needs a host-reachable base URL to POST
# heartbeat events back to the monitor. This must be the URL the host's cron
# jobs will use to reach the monitor, accounting for firewalls, NAT, or proxies.
# Examples: http://127.0.0.1:9090 (local), https://homelab.example.com (upstream proxy)
HOMELAB_MONITOR_PUBLIC_URL=  # e.g., http://127.0.0.1:9090 (dev) or http://127.0.0.1:29090 (prod)
#
# Optional:
# The monitor service is bound to 127.0.0.1 by default in docker-compose.yml.
# External access goes through the upstream nginx (or other) reverse proxy.
# /metrics is exposed unauthenticated for internal vmagent scraping; binding
# to 127.0.0.1 prevents accidental LAN exposure. To bind to all interfaces,
# edit docker-compose.yml's port mapping AND configure host firewall rules.
HOMELAB_MONITOR_PORT=9090
HOMELAB_MONITOR_HTTPS_ONLY_COOKIES=true
HOMELAB_MONITOR_DB_URL=sqlite+aiosqlite:////data/homelab-monitor.db
# VictoriaLogs retention period in days (default 30).
# Higher values = more disk; controlled per-stream by log_stream_budget collector.
HOMELAB_MONITOR_VL_RETENTION_DAYS=30

# IMAGE_TAG: which version of homelab-monitor to run.
# Recommend pinning to a specific version (e.g., v0.1.0) in production.
# Use 'latest' only for dev/staging.
IMAGE_TAG=latest

# Grafana public URL — what the browser sees for sub-path-served Grafana.
# Local dev: http://127.0.0.1:9090/api/grafana/
# Behind nginx/TLS: https://homelab.example.com/api/grafana/
# GRAFANA_PUBLIC_DOMAIN must match the host portion of GRAFANA_PUBLIC_URL.
GRAFANA_PUBLIC_URL=http://127.0.0.1:9090/api/grafana/
GRAFANA_PUBLIC_DOMAIN=127.0.0.1

# Host cron and docker integration:
HM_CRON_HOST_UID=1000
HM_CRON_HOST_GID=1000

# Host docker group GID — used by the monitor container to read /var/run/docker.sock.
# Find with: `getent group docker | cut -d: -f3`
# Default 999 is common for stock Docker installs; this host's GID may differ.
HM_HOST_DOCKER_GID=999

# Container log opt-out (CSV of container names to exclude from VictoriaLogs
# ingestion via Vector's docker_logs source).
# Empty/unset = tail ALL containers (recommended default).
# Example: VECTOR_DOCKER_EXCLUDE=homelab-cadvisor,homelab-vmagent
# VECTOR_DOCKER_EXCLUDE=

# STAGE-007-016: UDM CEF-over-syslog UDP listener.
# DELIBERATE LAN-exposure exception: this is the ONLY prod sidecar port
# host-published, and it binds 0.0.0.0 (not 127.0.0.1) so the UDM Pro on the
# LAN can ship syslog to vector. A container-internal sidecar cannot receive
# off-host UDP. Restrict via HM_UDM_SYSLOG_BIND_HOST if your network allows it.
HM_UDM_SYSLOG_BIND_HOST=0.0.0.0
HM_UDM_SYSLOG_PORT=5514

# =============================================================================
# SECURITY WARNING for HOMELAB_MONITOR_COMPOSE_DIR + HOMELAB_MONITOR_BUILD_CONTEXTS_DIR
# =============================================================================
# Every file under these directories will be read by the monitor container
# (read-only mount). Do NOT store any of the following under these paths:
#   - Plaintext secrets (.env files with API keys, passwords, tokens)
#   - TLS private keys
#   - Database connection strings with embedded credentials
#   - SSH keys
# Use docker compose secrets or external secret-management for credentials.
# =============================================================================

# STAGE-003-009: locally-built image-update detection.
# Path on the host to the compose directory containing docker-compose.yml.
# Mounted as /host-compose:ro inside the monitor container; the compose
# reader and source-hasher walk this tree but never write to it.
# Unset = feature disabled (default for public release).
# Example: HOMELAB_MONITOR_COMPOSE_DIR=/storage/docker/compose
# HOMELAB_MONITOR_COMPOSE_DIR=

# STAGE-003-009 (scope expansion): generic build-sources config.
# Mounts $HOMELAB_MONITOR_BUILD_CONTEXTS_DIR at /host-build-contexts:ro.
# Used by /config/docker/build-sources.yaml's build_context_roots remap rules.
# Unset = /dev/null (harmless). For complex layouts use a host-overrides
# docker-compose.override.yml.
# HOMELAB_MONITOR_BUILD_CONTEXTS_DIR=/storage/programs

# Override the in-container config path. Default: /config/docker/build-sources.yaml.
# HOMELAB_MONITOR_BUILD_SOURCES_CONFIG_PATH=/config/docker/build-sources.yaml

# ============================================================================
# STAGE-003-010 — Pull & Restart compose actions
# ============================================================================
# Per-attempt timeout in seconds. SIGTERM, 10s grace, then SIGKILL. Captured
# as state="timeout" in compose_actions audit row.
# HOMELAB_MONITOR_COMPOSE_ACTION_TIMEOUT_SECONDS=300
# HM_HOST_COMPOSE_GID=  # REQUIRED: GID of homelab-compose group on your host.
# After running `sudo bash scripts/host-setup.sh`, find it with:
#   getent group homelab-compose | cut -d: -f3
# Compose default is 994 (sentinel); override here if your host's GID differs.
